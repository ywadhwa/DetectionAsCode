{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment Mapping",
  "type": "object",
  "required": ["deployments"],
  "properties": {
    "deployments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["environment", "tenant", "platform", "content_pack", "action"],
        "properties": {
          "environment": {"type": "string"},
          "tenant": {"type": "string"},
          "platform": {"type": "string", "enum": ["sentinel", "splunk"]},
          "content_pack": {"type": "string"},
          "action": {"type": "string", "enum": ["deploy", "remove"]},
          "dry_run": {"type": "boolean"}
        }
      }
    }
  },
  "additionalProperties": false
}
